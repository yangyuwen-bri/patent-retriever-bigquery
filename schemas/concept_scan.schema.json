{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ConceptScan",
  "type": "object",
  "required": ["scan_metadata", "patterns", "summary"],
  "properties": {
    "scan_metadata": {
      "type": "object",
      "required": ["scan_date", "input_type"],
      "properties": {
        "scan_date": {"type": "string"},
        "input_type": {"type": "string"},
        "industry": {"type": "string"},
        "source": {"type": "string"}
      },
      "additionalProperties": true
    },
    "patterns": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["pattern_id", "title", "score", "claim_angles"],
        "properties": {
          "pattern_id": {"type": "string"},
          "title": {"type": "string"},
          "category": {"type": "string"},
          "components": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": {"type": "string"},
                "domain": {"type": "string"},
                "role": {"type": "string"}
              },
              "additionalProperties": true
            }
          },
          "score": {
            "type": "object",
            "required": ["total"],
            "properties": {
              "distinctiveness": {"type": "number"},
              "sophistication": {"type": "number"},
              "system_impact": {"type": "number"},
              "frame_shift": {"type": "number"},
              "total": {"type": "number"}
            },
            "additionalProperties": true
          },
          "problem_solution_benefit": {
            "type": "object",
            "properties": {
              "problem": {"type": "string"},
              "solution": {"type": "string"},
              "benefit": {"type": "string"}
            },
            "additionalProperties": true
          },
          "patent_signals": {
            "type": "object",
            "properties": {
              "market_demand": {"type": "string"},
              "competitive_value": {"type": "string"},
              "novelty_confidence": {"type": "string"}
            },
            "additionalProperties": true
          },
          "claim_angles": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string"}
          }
        },
        "additionalProperties": true
      }
    },
    "summary": {
      "type": "object",
      "properties": {
        "total_patterns": {"type": "integer"},
        "high_value_patterns": {"type": "integer"},
        "recommended_focus": {"type": "string"}
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
