{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "QueryPlan",
  "type": "object",
  "required": ["task_id", "topic", "source", "table", "query_rounds"],
  "properties": {
    "task_id": {"type": "string"},
    "topic": {"type": "string"},
    "source": {"type": "string", "enum": ["google_patents_bigquery"]},
    "table": {"type": "string"},
    "threshold": {"type": "number"},
    "query_rounds": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["round_id", "intent", "limit", "filters"],
        "properties": {
          "round_id": {"type": "string"},
          "intent": {"type": "string"},
          "limit": {"type": "integer", "minimum": 1},
          "filters": {
            "type": "object",
            "properties": {
              "keywords_all": {"type": "array", "items": {"type": "string"}},
              "keywords_any": {"type": "array", "items": {"type": "string"}},
              "keywords_anchor_any": {"type": "array", "items": {"type": "string"}},
              "keywords_not": {"type": "array", "items": {"type": "string"}},
              "ipc_prefix_any": {"type": "array", "items": {"type": "string"}},
              "cpc_prefix_any": {"type": "array", "items": {"type": "string"}},
              "assignee_any": {"type": "array", "items": {"type": "string"}},
              "inventor_any": {"type": "array", "items": {"type": "string"}},
              "country_in": {"type": "array", "items": {"type": "string"}},
              "pub_date_from": {"type": "integer"},
              "pub_date_to": {"type": "integer"},
              "filing_date_from": {"type": "integer"},
              "filing_date_to": {"type": "integer"}
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": true
      }
    },
    "mapping_notes": {
      "type": "array",
      "items": {"type": "string"}
    }
  },
  "additionalProperties": true
}
